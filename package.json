{
  "name": "rates-fetcher",
  "version": "1.0.0",
  "description": "Scrapes exchange rates from remittance providers using Playwright",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "scrape": "node src/index.js",
    "scrape:all": "node src/index.js --all",
    "scrape:fast": "node src/index.js --fast",
    "scrape:slow": "node src/index.js --slow",
    "scrape:wise": "node src/index.js --provider=Wise",
    "scrape:remitly": "node src/index.js --provider=Remitly",
    "scrape:worldremit": "node src/index.js --provider=WorldRemit",
    "scrape:western-union": "node src/index.js --provider=Western Union",
    "scrape:xoom": "node src/index.js --provider=Xoom",
    "scrape:taptap": "node src/index.js --provider=Taptap Send",
    "scrape:ria": "node src/index.js --provider=Ria",
    "scrape:panda": "node src/index.js --provider=Panda Remit",
    "scrape:sendwave": "node src/index.js --provider=Sendwave",
    "scrape:transfergo": "node src/index.js --provider=TransferGo",
    "scrape:moneygram": "node src/index.js --provider=MoneyGram",
    "test": "node tests/runner.js",
    "test-provider": "node src/test-provider.js",
    "generate-sql": "node scripts/generate-sql.js",
    "d1:init": "wrangler d1 create currency-rates && wrangler d1 execute currency-rates --remote --file=./schema.sql",
    "d1:migrate": "wrangler d1 execute currency-rates --remote --file=./schema.sql",
    "retry": "node src/index.js --retry",
    "retry:wise": "node src/index.js --retry --provider=Wise",
    "retry:remitly": "node src/index.js --retry --provider=Remitly",
    "retry:worldremit": "node src/index.js --retry --provider=WorldRemit",
    "retry:western-union": "node src/index.js --retry --provider=Western Union",
    "retry:xoom": "node src/index.js --retry --provider=Xoom",
    "retry:taptap": "node src/index.js --retry --provider=Taptap Send",
    "retry:ria": "node src/index.js --retry --provider=Ria",
    "retry:panda": "node src/index.js --retry --provider=Panda Remit",
    "retry:sendwave": "node src/index.js --retry --provider=Sendwave",
    "retry:transfergo": "node src/index.js --retry --provider=TransferGo",
    "retry:moneygram": "node src/index.js --retry --provider=MoneyGram"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cheerio": "^1.2.0",
    "csv-parse": "^6.2.1",
    "playwright": "^1.59.1"
  }
}
